# Throwaway LOCAL DEV config, not the production Caddyfile from the guide's Part 5.
#
# Unifies the entry service and the Vite dev server under one origin so the
# entry service's relative redirects (/auth, /c/{id}) resolve correctly, and
# so localStorage (which the frontend's auth session lives in) is scoped to
# one hostname instead of being split across two dev ports.
#
# Note: in dev mode, Open WebUI's frontend calls the backend API via an
# ABSOLUTE http://<host>:8080 URL (see src/lib/constants.ts, WEBUI_HOSTNAME),
# not through whatever served the page. So this proxy does NOT need to route
# /api/* anywhere -- the browser hits port 8080 directly for those. Only
# page routes (-> Vite) and /enter (-> entry service) need to go through here.
#
# Run with: caddy run --config Caddyfile.dev
#
# If you get "address already in use" on port 2019, another Caddy instance's
# admin API already owns it -- the {admin off} line below disables this
# instance's admin API entirely, which we don't need for local testing.

{
	admin off
}

:8888 {
	handle /enter* {
		reverse_proxy localhost:9000
	}
	handle {
		# NOTE: pointed at 10.2.0.2 instead of localhost because the npm run dev
		# process turned out to be running in a different WSL network namespace
		# than Caddy/entry-service. This IP is assigned by WSL2's NAT and can
		# change on reboot -- if this stops working later, re-run
		# `curl -I http://<ip>:5173` from candidate WSL IPs (or better: restart
		# `npm run dev` from the same terminal/profile you use for the other
		# processes so everything shares one loopback again).
		reverse_proxy 10.2.0.2:5173
	}
}
